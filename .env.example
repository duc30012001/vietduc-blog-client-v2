# ============================================
# App Configuration
# ============================================

# Backend API base URL
NEXT_PUBLIC_API_URL="http://localhost:8080/v1"

# Public-facing site URL (used for OG images, canonical URLs, sitemaps)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Site name (used in title tags, OG metadata)
NEXT_PUBLIC_SITE_NAME="Duck Blog"

# SEO keywords (comma-separated, used in meta keywords tag)
NEXT_PUBLIC_SITE_KEYWORDS="blog, technology, programming, web development"

# ============================================
# Analytics
# ============================================

# Google Analytics Measurement ID (leave empty to disable)
NEXT_PUBLIC_GA_ID=""

# ============================================
# Cache Revalidation
# ============================================

# Secret token for on-demand cache revalidation API
REVALIDATION_SECRET=""

# Admin panel URL (used for CORS on revalidation API, leave empty to allow all origins)
ADMIN_URL="http://localhost:5173"

# ============================================
# Docker Configuration
# ============================================

# Port to expose the app on (host port)
APP_PORT=3001

# Docker container resource limits
DOCKER_MEMORY_LIMIT=2g
DOCKER_CPU_LIMIT=2.0
